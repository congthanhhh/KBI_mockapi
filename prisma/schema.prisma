generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model ItemGroup {
    id              String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    group_code      String?      @db.VarChar(50)
    group_name      String       @db.VarChar(255)
    description     String?
    default_hs_code String?      @db.VarChar(20)
    create_at       DateTime     @default(now()) @db.Timestamptz(6)
    update_at       DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at       DateTime?    @db.Timestamptz(6)
    is_delete       Boolean      @default(false)
    items           ItemMaster[]

    @@map("item_groups")
}

model ItemMaster {
    id               String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    item_code        String               @db.VarChar(100)
    item_name        String               @db.VarChar(255)
    item_description String?
    item_group_id    String?              @db.Uuid
    unit             String?              @db.VarChar(50)
    item_type        String?              @db.VarChar(50)
    origin_country   String?              @db.VarChar(100)
    brand            String?              @db.VarChar(100)
    model            String?              @db.VarChar(100)
    is_new           Boolean              @default(true)
    lead_time_days   Int                  @default(0)
    moq              Decimal              @default(0) @db.Decimal(18, 4)
    is_active        Boolean              @default(true)
    create_at        DateTime             @default(now()) @db.Timestamptz(6)
    update_at        DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at        DateTime?            @db.Timestamptz(6)
    is_delete        Boolean              @default(false)
    item_group       ItemGroup?           @relation(fields: [item_group_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    customs_profiles ItemCustomsProfile[]
    purchase_order_lines PurchaseOrderLine[]
    po_lot_lines    PoLotLine[]
    delivery_order_lines DeliveryOrderLine[]
    shipment_lines  ShipmentLine[]

    @@map("item_master")
}

model ItemCustomsProfile {
    id                              String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    item_id                         String     @db.Uuid
    hs_code                         String?    @db.VarChar(20)
    import_duty_rate                Decimal?   @db.Decimal(5, 2)
    vat_rate                        Decimal?   @db.Decimal(5, 2)
    co_form                         String?    @db.VarChar(50)
    co_tax_note                     String?
    customs_type                    String?    @db.VarChar(50)
    customs_note                    String?
    reference_doc_no                String?    @db.VarChar(100)
    location_code                   String?    @db.VarChar(50)
    tax_note                        String?
    preferential_import_duty_rate   Decimal?   @db.Decimal(5, 2)
    is_default                      Boolean    @default(true)
    create_at                       DateTime   @default(now()) @db.Timestamptz(6)
    update_at                       DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at                       DateTime?  @db.Timestamptz(6)
    is_delete                       Boolean    @default(false)
    item                            ItemMaster @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    purchase_order_lines            PurchaseOrderLine[]

    @@map("item_customs_profiles")
}

model Currency {
    id             String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    currency_code  String     @unique @db.VarChar(10)
    currency_name  String     @db.VarChar(100)
    symbol         String?    @db.VarChar(10)
    decimal_places Int        @default(2)
    is_active      Boolean    @default(true)
    create_at      DateTime   @default(now()) @db.Timestamptz(6)
    update_at      DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at      DateTime?  @db.Timestamptz(6)
    is_delete      Boolean    @default(false)
    suppliers      Supplier[] @relation("SupplierDefaultCurrency")
    purchase_orders PurchaseOrder[]
    quotations     Quotation[]

    @@map("currencies")
}

model Incoterm {
    id            String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    incoterm_code String     @unique @db.VarChar(20)
    incoterm_name String     @db.VarChar(100)
    description   String?
    is_active     Boolean    @default(true)
    create_at     DateTime   @default(now()) @db.Timestamptz(6)
    update_at     DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at     DateTime?  @db.Timestamptz(6)
    is_delete     Boolean    @default(false)
    suppliers     Supplier[] @relation("SupplierDefaultIncoterm")
    purchase_orders PurchaseOrder[]

    @@map("incoterms")
}

model TransportMode {
    id                       String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    mode_code                String                  @db.VarChar(50)
    mode_name                String                  @db.VarChar(100)
    mode_type                String                  @db.VarChar(50)
    description              String?
    is_international         Boolean                 @default(true)
    is_active                Boolean                 @default(true)
    create_at                DateTime                @default(now()) @db.Timestamptz(6)
    update_at                DateTime                @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at                DateTime?               @db.Timestamptz(6)
    is_delete                Boolean                 @default(false)
    supplier_transport_modes SupplierTransportMode[]
    purchase_orders          PurchaseOrder[]
    delivery_orders          DeliveryOrder[]
    shipments                Shipment[]

    @@map("transport_modes")
}

model Supplier {
    id                       String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    supplier_code            String                  @db.VarChar(50)
    supplier_name            String                  @db.VarChar(255)
    supplier_roles           String[]                @default(["SUPPLIER"])
    country                  String?                 @db.VarChar(100)
    address                  String?
    contact_name             String?                 @db.VarChar(100)
    contact_email            String?                 @db.VarChar(100)
    contact_phone            String?                 @db.VarChar(50)
    payment_term             String?                 @db.VarChar(100)
    default_currency_code    String?                 @db.VarChar(10)
    default_incoterm_code    String?                 @db.VarChar(20)
    default_currency_id      String?                 @db.Uuid
    default_incoterm_id      String?                 @db.Uuid
    lead_time_days           Int                     @default(0)
    is_active                Boolean                 @default(true)
    create_at                DateTime                @default(now()) @db.Timestamptz(6)
    update_at                DateTime                @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at                DateTime?               @db.Timestamptz(6)
    is_delete                Boolean                 @default(false)
    default_currency         Currency?               @relation("SupplierDefaultCurrency", fields: [default_currency_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    default_incoterm         Incoterm?               @relation("SupplierDefaultIncoterm", fields: [default_incoterm_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    supplier_transport_modes SupplierTransportMode[]
    purchase_orders          PurchaseOrder[]
    quotations               Quotation[]
    shipments_as_forwarder   Shipment[]                @relation("ShipmentForwarder")

    @@map("suppliers")
}

model SupplierTransportMode {
    id                String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    supplier_id       String        @db.Uuid
    transport_mode_id String        @db.Uuid
    is_default        Boolean       @default(false)
    create_at         DateTime      @default(now()) @db.Timestamptz(6)
    update_at         DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at         DateTime?     @db.Timestamptz(6)
    is_delete         Boolean       @default(false)
    supplier          Supplier      @relation(fields: [supplier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    transport_mode    TransportMode @relation(fields: [transport_mode_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

    @@map("supplier_transport_modes")
}

model PurchaseOrder {
    id                    String                       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    po_no                 String                       @db.VarChar(100)
    contract_no           String?                      @db.VarChar(100)
    supplier_id           String                       @db.Uuid
    currency_id           String?                      @db.Uuid
    incoterm_id           String?                      @db.Uuid
    transport_mode_id     String?                      @db.Uuid
    po_type               String?                      @db.VarChar(50)
    payment_term          String?                      @db.VarChar(100)
    exchange_rate         Decimal                      @default(1) @db.Decimal(18, 6)
    expected_etd          DateTime?                    @db.Date
    expected_eta          DateTime?                    @db.Date
    status                String                       @default("DRAFT") @db.VarChar(30)
    sent_at               DateTime?                    @db.Timestamptz(6)
    confirmed_at          DateTime?                    @db.Timestamptz(6)
    cancelled_at          DateTime?                    @db.Timestamptz(6)
    cancel_reason         String?
    notes                 String?
    create_at             DateTime                     @default(now()) @db.Timestamptz(6)
    update_at             DateTime                     @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at             DateTime?                    @db.Timestamptz(6)
    is_delete             Boolean                      @default(false)
    supplier              Supplier                     @relation(fields: [supplier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    currency              Currency?                    @relation(fields: [currency_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    incoterm              Incoterm?                    @relation(fields: [incoterm_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    transport_mode        TransportMode?               @relation(fields: [transport_mode_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    lines                 PurchaseOrderLine[]
    confirmations         PurchaseOrderConfirmation[]
    delivery_slots        PoDeliverySlot[]
    lots                  PoLot[]
    delivery_orders       DeliveryOrder[]
    shipments             Shipment[]

    @@map("purchase_orders")
}

model PurchaseOrderLine {
    id                             String                          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    purchase_order_id              String                          @db.Uuid
    item_id                        String                          @db.Uuid
    item_customs_profile_id        String?                         @db.Uuid
    line_no                        Int
    item_description               String?
    qty_ordered                    Decimal                         @db.Decimal(18, 4)
    unit                           String                          @db.VarChar(50)
    unit_price                     Decimal                         @default(0) @db.Decimal(18, 4)
    tax_rate                       Decimal                         @default(0) @db.Decimal(5, 2)
    discount_pct                   Decimal                         @default(0) @db.Decimal(5, 2)
    qty_confirmed                  Decimal                         @default(0) @db.Decimal(18, 4)
    qty_lotted                     Decimal                         @default(0) @db.Decimal(18, 4)
    qty_shipped                    Decimal                         @default(0) @db.Decimal(18, 4)
    qty_received                   Decimal                         @default(0) @db.Decimal(18, 4)
    expected_eta_line              DateTime?                       @db.Date
    notes                          String?
    create_at                      DateTime                        @default(now()) @db.Timestamptz(6)
    update_at                      DateTime                        @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at                      DateTime?                       @db.Timestamptz(6)
    is_delete                      Boolean                         @default(false)
    purchase_order                 PurchaseOrder                   @relation(fields: [purchase_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    item                           ItemMaster                      @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    item_customs_profile           ItemCustomsProfile?             @relation(fields: [item_customs_profile_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    confirmation_lines             PurchaseOrderConfirmationLine[]
    lot_lines                      PoLotLine[]
    delivery_order_lines           DeliveryOrderLine[]
    shipment_lines                 ShipmentLine[]

    @@map("purchase_order_lines")
}

model PurchaseOrderConfirmation {
    id                     String                          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    purchase_order_id      String                          @db.Uuid
    confirmed_by           String?                         @db.VarChar(100)
    confirmed_at           DateTime                        @default(now()) @db.Timestamptz(6)
    supplier_ref_no        String?                         @db.VarChar(100)
    is_full_shipment       Boolean                         @default(true)
    allow_partial_shipment Boolean                         @default(false)
    note                   String?
    create_at              DateTime                        @default(now()) @db.Timestamptz(6)
    update_at              DateTime                        @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at              DateTime?                       @db.Timestamptz(6)
    is_delete              Boolean                         @default(false)
    purchase_order         PurchaseOrder                   @relation(fields: [purchase_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    lines                  PurchaseOrderConfirmationLine[]

    @@map("purchase_order_confirmations")
}

model PurchaseOrderConfirmationLine {
    id                             String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    purchase_order_confirmation_id String                    @db.Uuid
    purchase_order_line_id         String                    @db.Uuid
    confirmed_qty                  Decimal                   @db.Decimal(18, 4)
    cargo_ready_date               DateTime?                 @db.Date
    can_fulfill                    Boolean                   @default(true)
    allow_partial_shipment         Boolean                   @default(false)
    note                           String?
    create_at                      DateTime                  @default(now()) @db.Timestamptz(6)
    update_at                      DateTime                  @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at                      DateTime?                 @db.Timestamptz(6)
    is_delete                      Boolean                   @default(false)
    confirmation                   PurchaseOrderConfirmation @relation(fields: [purchase_order_confirmation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    purchase_order_line            PurchaseOrderLine         @relation(fields: [purchase_order_line_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

    @@map("purchase_order_confirmation_lines")
}

model PoDeliverySlot {
    id                         String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    purchase_order_id          String        @db.Uuid
    slot_no                    String        @db.VarChar(50)
    slot_name                  String?       @db.VarChar(100)
    planned_cargo_ready_date   DateTime?     @db.Date
    planned_etd                DateTime?     @db.Date
    planned_eta                DateTime?     @db.Date
    delivery_address           String?
    warehouse_name             String?       @db.VarChar(255)
    status                     String        @default("PLANNED") @db.VarChar(30)
    sort_order                 Int           @default(1)
    notes                      String?
    create_at                  DateTime      @default(now()) @db.Timestamptz(6)
    update_at                  DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at                  DateTime?     @db.Timestamptz(6)
    is_delete                  Boolean       @default(false)
    purchase_order             PurchaseOrder @relation(fields: [purchase_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    lots                       PoLot[]

    @@map("po_delivery_slots")
}

model PoLot {
    id                         String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    purchase_order_id          String         @db.Uuid
    delivery_slot_id           String         @db.Uuid
    lot_no                     String         @db.VarChar(50)
    lot_name                   String?        @db.VarChar(100)
    status                     String         @default("PLANNED") @db.VarChar(30)
    planned_cargo_ready_date   DateTime?      @db.Date
    planned_etd                DateTime?      @db.Date
    planned_eta                DateTime?      @db.Date
    sort_order                 Int            @default(1)
    notes                      String?
    create_at                  DateTime       @default(now()) @db.Timestamptz(6)
    update_at                  DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at                  DateTime?      @db.Timestamptz(6)
    is_delete                  Boolean        @default(false)
    purchase_order             PurchaseOrder  @relation(fields: [purchase_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    delivery_slot              PoDeliverySlot @relation(fields: [delivery_slot_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    lot_lines                  PoLotLine[]
    delivery_order_lots        DeliveryOrderLot[]
    shipment_lines             ShipmentLine[]

    @@map("po_lots")
}

model PoLotLine {
    id                       String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    po_lot_id                String            @db.Uuid
    purchase_order_line_id   String            @db.Uuid
    item_id                  String            @db.Uuid
    qty_lotted               Decimal           @db.Decimal(18, 4)
    unit                     String            @db.VarChar(50)
    notes                    String?
    create_at                DateTime          @default(now()) @db.Timestamptz(6)
    update_at                DateTime          @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at                DateTime?         @db.Timestamptz(6)
    is_delete                Boolean           @default(false)
    po_lot                   PoLot             @relation(fields: [po_lot_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    purchase_order_line      PurchaseOrderLine @relation(fields: [purchase_order_line_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    item                     ItemMaster        @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

    @@map("po_lot_lines")
}

model DeliveryOrder {
    id                         String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    do_no                      String              @db.VarChar(50)
    purchase_order_id          String              @db.Uuid
    transport_mode_id          String?             @db.Uuid
    status                     String              @default("DRAFT") @db.VarChar(30)
    planned_cargo_ready_date   DateTime?           @db.Date
    planned_etd                DateTime?           @db.Date
    planned_eta                DateTime?           @db.Date
    origin_address             String?
    destination_address        String?
    warehouse_name             String?             @db.VarChar(255)
    requested_by               String?             @db.VarChar(150)
    handled_by                 String?             @db.VarChar(150)
    notes                      String?
    create_at                  DateTime            @default(now()) @db.Timestamptz(6)
    update_at                  DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at                  DateTime?           @db.Timestamptz(6)
    is_delete                  Boolean             @default(false)
    purchase_order             PurchaseOrder       @relation(fields: [purchase_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    transport_mode             TransportMode?      @relation(fields: [transport_mode_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    lots                       DeliveryOrderLot[]
    lines                      DeliveryOrderLine[]
    shipments                  Shipment[]

    @@map("delivery_orders")
}

model DeliveryOrderLot {
    id                         String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    delivery_order_id          String              @db.Uuid
    po_lot_id                  String              @db.Uuid
    lot_no                     String              @db.VarChar(50)
    lot_name                   String?             @db.VarChar(150)
    planned_cargo_ready_date   DateTime?           @db.Date
    planned_etd                DateTime?           @db.Date
    planned_eta                DateTime?           @db.Date
    notes                      String?
    create_at                  DateTime            @default(now()) @db.Timestamptz(6)
    update_at                  DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at                  DateTime?           @db.Timestamptz(6)
    is_delete                  Boolean             @default(false)
    delivery_order             DeliveryOrder       @relation(fields: [delivery_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    po_lot                     PoLot               @relation(fields: [po_lot_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    lines                      DeliveryOrderLine[]
    shipment_lines             ShipmentLine[]

    @@map("delivery_order_lots")
}

model DeliveryOrderLine {
    id                       String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    delivery_order_id        String            @db.Uuid
    delivery_order_lot_id    String            @db.Uuid
    purchase_order_line_id   String            @db.Uuid
    item_id                  String            @db.Uuid
    item_description         String?
    qty                      Decimal           @db.Decimal(18, 4)
    unit                     String            @db.VarChar(50)
    notes                    String?
    create_at                DateTime          @default(now()) @db.Timestamptz(6)
    update_at                DateTime          @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at                DateTime?         @db.Timestamptz(6)
    is_delete                Boolean           @default(false)
    delivery_order           DeliveryOrder     @relation(fields: [delivery_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    delivery_order_lot       DeliveryOrderLot  @relation(fields: [delivery_order_lot_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    purchase_order_line      PurchaseOrderLine @relation(fields: [purchase_order_line_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    item                     ItemMaster        @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    shipment_lines           ShipmentLine[]

    @@map("delivery_order_lines")
}

model Quotation {
    id                         String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    quotation_group_id         String                  @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    quotation_no               String                  @db.VarChar(50)
    version                    Int                     @default(1)
    ref_type                   String                  @db.VarChar(30)
    ref_id                     String                  @db.Uuid
    supplier_id                String                  @db.Uuid
    quotation_type             String                  @db.VarChar(30)
    currency_id                String                  @db.Uuid
    exchange_rate              Decimal                 @default(1) @db.Decimal(18, 6)
    status                     String                  @default("DRAFT") @db.VarChar(30)
    is_final                   Boolean                 @default(false)
    quoted_at                  DateTime?               @db.Timestamptz(6)
    valid_until                DateTime?               @db.Date
    submitted_at               DateTime?               @db.Timestamptz(6)
    confirmed_at               DateTime?               @db.Timestamptz(6)
    rejected_at                DateTime?               @db.Timestamptz(6)
    cancelled_at               DateTime?               @db.Timestamptz(6)
    total_amount               Decimal                 @default(0) @db.Decimal(18, 4)
    total_tax_amount           Decimal                 @default(0) @db.Decimal(18, 4)
    grand_total_amount         Decimal                 @default(0) @db.Decimal(18, 4)
    note                       String?
    create_at                  DateTime                @default(now()) @db.Timestamptz(6)
    update_at                  DateTime                @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at                  DateTime?               @db.Timestamptz(6)
    is_delete                  Boolean                 @default(false)
    supplier                   Supplier                @relation(fields: [supplier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    currency                   Currency                @relation(fields: [currency_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    charge_lines               QuotationChargeLine[]
    events                     QuotationEvent[]
    shipments                  Shipment[]

    @@map("quotations")
}

model QuotationChargeLine {
    id               String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    quotation_id     String      @db.Uuid
    line_no          Int
    charge_type      String      @db.VarChar(50)
    description      String
    quantity         Decimal     @default(1) @db.Decimal(18, 4)
    unit             String?     @db.VarChar(50)
    unit_price       Decimal     @default(0) @db.Decimal(18, 4)
    amount           Decimal     @default(0) @db.Decimal(18, 4)
    tax_rate         Decimal     @default(0) @db.Decimal(5, 2)
    tax_amount       Decimal     @default(0) @db.Decimal(18, 4)
    total_amount     Decimal     @default(0) @db.Decimal(18, 4)
    note             String?
    create_at        DateTime    @default(now()) @db.Timestamptz(6)
    update_at        DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at        DateTime?   @db.Timestamptz(6)
    is_delete        Boolean     @default(false)
    quotation        Quotation   @relation(fields: [quotation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

    @@map("quotation_charge_lines")
}

model QuotationEvent {
    id             String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    quotation_id   String      @db.Uuid
    event_type     String      @db.VarChar(50)
    old_status     String?     @db.VarChar(30)
    new_status     String?     @db.VarChar(30)
    actor_name     String?     @db.VarChar(150)
    event_at       DateTime    @default(now()) @db.Timestamptz(6)
    note           String?
    payload        Json?
    create_at      DateTime    @default(now()) @db.Timestamptz(6)
    update_at      DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at      DateTime?   @db.Timestamptz(6)
    is_delete      Boolean     @default(false)
    quotation      Quotation   @relation(fields: [quotation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

    @@map("quotation_events")
}

model Shipment {
    id                 String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    shipment_no        String              @db.VarChar(50)
    delivery_order_id  String              @db.Uuid
    purchase_order_id  String              @db.Uuid
    final_quotation_id String?             @db.Uuid
    transport_mode_id  String?             @db.Uuid
    forwarder_id       String?             @db.Uuid
    carrier            String?             @db.VarChar(150)
    mode               String              @db.VarChar(30)
    vessel_flight      String?             @db.VarChar(150)
    voyage_no          String?             @db.VarChar(100)
    bl_awb_no          String?             @db.VarChar(100)
    container_no       Json?
    pol                String?             @db.VarChar(150)
    pod                String?             @db.VarChar(150)
    etd                DateTime?           @db.Date
    eta                DateTime?           @db.Date
    atd                DateTime?           @db.Date
    ata                DateTime?           @db.Date
    status             String              @default("BOOKING_PENDING") @db.VarChar(30)
    customs_channel    String?             @db.VarChar(20)
    package_qty        Decimal?            @db.Decimal(18, 4)
    gross_weight       Decimal?            @db.Decimal(18, 4)
    net_weight         Decimal?            @db.Decimal(18, 4)
    cbm                Decimal?            @db.Decimal(18, 4)
    notes              String?
    create_at          DateTime            @default(now()) @db.Timestamptz(6)
    update_at          DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at          DateTime?           @db.Timestamptz(6)
    is_delete          Boolean             @default(false)
    delivery_order     DeliveryOrder       @relation(fields: [delivery_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    purchase_order     PurchaseOrder       @relation(fields: [purchase_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    final_quotation    Quotation?          @relation(fields: [final_quotation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    transport_mode     TransportMode?      @relation(fields: [transport_mode_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    forwarder          Supplier?           @relation("ShipmentForwarder", fields: [forwarder_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    lines              ShipmentLine[]
    milestones         ShipmentMilestone[]
    documents          ShipmentDocument[]

    @@map("shipments")
}

model ShipmentLine {
    id                       String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    shipment_id              String            @db.Uuid
    delivery_order_line_id   String            @db.Uuid
    delivery_order_lot_id    String?           @db.Uuid
    purchase_order_line_id   String            @db.Uuid
    po_lot_id                String?           @db.Uuid
    item_id                  String            @db.Uuid
    item_description         String?
    qty_shipped              Decimal           @db.Decimal(18, 4)
    unit                     String            @db.VarChar(50)
    lot_no                   String?           @db.VarChar(50)
    notes                    String?
    create_at                DateTime          @default(now()) @db.Timestamptz(6)
    update_at                DateTime          @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at                DateTime?         @db.Timestamptz(6)
    is_delete                Boolean           @default(false)
    shipment                 Shipment          @relation(fields: [shipment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    delivery_order_line      DeliveryOrderLine @relation(fields: [delivery_order_line_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    delivery_order_lot       DeliveryOrderLot? @relation(fields: [delivery_order_lot_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    purchase_order_line      PurchaseOrderLine @relation(fields: [purchase_order_line_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    po_lot                   PoLot?            @relation(fields: [po_lot_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    item                     ItemMaster        @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

    @@map("shipment_lines")
}

model ShipmentMilestone {
    id              String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    shipment_id     String             @db.Uuid
    sequence_no     Int
    milestone_code  String             @db.VarChar(50)
    milestone_name  String             @db.VarChar(150)
    planned_at      DateTime?          @db.Timestamptz(6)
    actual_at       DateTime?          @db.Timestamptz(6)
    status          String             @default("PENDING") @db.VarChar(30)
    notes           String?
    create_at       DateTime           @default(now()) @db.Timestamptz(6)
    update_at       DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at       DateTime?          @db.Timestamptz(6)
    is_delete       Boolean            @default(false)
    shipment        Shipment           @relation(fields: [shipment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    documents       ShipmentDocument[]

    @@map("shipment_milestones")
}

model ShipmentDocument {
    id            String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    shipment_id   String             @db.Uuid
    milestone_id  String?            @db.Uuid
    document_type String             @db.VarChar(50)
    document_no   String?            @db.VarChar(100)
    file_url      String?
    file_name     String?            @db.VarChar(255)
    mime_type     String?            @db.VarChar(100)
    issued_date   DateTime?          @db.Date
    received_at   DateTime?          @db.Timestamptz(6)
    status        String             @default("RECEIVED") @db.VarChar(30)
    notes         String?
    create_at     DateTime           @default(now()) @db.Timestamptz(6)
    update_at     DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
    delete_at     DateTime?          @db.Timestamptz(6)
    is_delete     Boolean            @default(false)
    shipment      Shipment           @relation(fields: [shipment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
    milestone     ShipmentMilestone? @relation(fields: [milestone_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

    @@map("shipment_documents")
}
