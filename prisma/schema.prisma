generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model MasterItem {
    id                     String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    item_code              String?          @db.VarChar(50)
    item_group_name        String?
    item_name_vi           String?
    item_name_en           String?
    model                  String?          @db.VarChar(100)
    description            String
    normalized_description String?
    default_hs_code        String?          @db.VarChar(20)
    classification_code    String?          @db.VarChar(50)
    note                   String?
    create_at              DateTime?        @default(now()) @db.Timestamp(6)
    update_at              DateTime?        @default(now()) @updatedAt @db.Timestamp(6)
    is_delete              Boolean?         @default(false)
    delete_at              DateTime?        @db.Timestamp(6)
    tax_profiles           ItemTaxProfile[]

    @@map("master_items")
}

model ItemTaxProfile {
    id                    String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    item_id               String      @db.Uuid
    hs_code               String?     @db.VarChar(20)
    import_tax_rate       Decimal?    @db.Decimal(5, 2)
    vat_rate              Decimal?    @db.Decimal(5, 2)
    tariff_code           String?     @db.VarChar(50)
    classification_code   String?     @db.VarChar(50)
    co_note               String?
    preferential_tax_rate Decimal?    @db.Decimal(5, 2)
    tax_note              String?
    create_at             DateTime?   @default(now()) @db.Timestamp(6)
    update_at             DateTime?   @default(now()) @updatedAt @db.Timestamp(6)
    is_delete             Boolean?    @default(false)
    delete_at             DateTime?   @db.Timestamp(6)
    item                  MasterItem  @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

    @@map("item_tax_profiles")
}
